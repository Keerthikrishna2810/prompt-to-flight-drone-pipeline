Panels:
  - Class: rviz_common/Displays
    Name: Displays
  - Class: rviz_common/Views
    Name: Views
Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/Grid
      Name: Grid
      Enabled: true
      Cell Size: 10
      Plane Cell Count: 20
      Color: 160; 160; 164
    - Class: rviz_default_plugins/MarkerArray
      Name: Planned Routes
      Enabled: true
      Topic:
        Value: /squad/planned_routes
        Depth: 5
        Durability Policy: Volatile
        Reliability Policy: Reliable
    - Class: rviz_default_plugins/MarkerArray
      Name: Live Positions
      Enabled: true
      Topic:
        Value: /squad/live_positions
        Depth: 5
        Durability Policy: Volatile
        Reliability Policy: Reliable
  Global Options:
    Fixed Frame: map
    Background Color: 30; 30; 30
  Tools:
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 80
      Focal Point:
        X: 0
        Y: 0
        Z: 0
      Pitch: 0.6
      Yaw: 0.8
Window Geometry:
  Height: 900
  Width: 1400
